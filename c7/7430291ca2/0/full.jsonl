 <input\n60:             type=\"text\"\n61:             id=\"name\"\n62:             name=\"name\"\n63:             value={formData.name}\n64:             onChange={handleChange}\n65:             placeholder=\"Enter project name\"\n66:             required\n67:           />\n68:         </div>\n69: \n70:         <div className=\"form-group\">\n71:           <label htmlFor=\"location\">Location</label>\n72:           <input\n73:             type=\"text\"\n74:             id=\"location\"\n75:             name=\"location\"\n76:             value={formData.location}\n77:             onChange={handleChange}\n78:             placeholder=\"Enter location\"\n79:             required\n80:           />\n81:         </div>\n82: \n83:         <div className=\"form-group\">\n84:           <label htmlFor=\"landLength\">Land Length (ft)</label>\n85:           <input\n86:             type=\"number\"\n87:             id=\"landLength\"\n88:             name=\"landLength\"\n89:             value={formData.landLength}\n90:             onChange={handleChange}\n91:             placeholder=\"Enter land length\"\n92:             required\n93:           />\n94:         </div>\n95: \n96:         <div className=\"form-group\">\n97:           <label htmlFor=\"landWidth\">Land Width (ft)</label>\n98:           <input\n99:             type=\"number\"\n100:             id=\"landWidth\"\n101:             name=\"landWidth\"\n102:             value={formData.landWidth}\n103:             onChange={handleChange}\n104:             placeholder=\"Enter land width\"\n105:             required\n106:           />\n107:         </div>\n108: \n109:         <div className=\"form-group\">\n110:           <label htmlFor=\"numberOfPlots\">Number of Plots</label>\n111:           <input\n112:             type=\"number\"\n113:             id=\"numberOfPlots\"\n114:             name=\"numberOfPlots\"\n115:             value={formData.numberOfPlots}\n116:             onChange={handleChange}\n117:             placeholder=\"Enter number of plots\"\n118:             required\n119:           />\n120:         </div>\n121: \n122:         {numPlots > 0 && (\n123:           <div className=\"grid-info\">\n124:             <p>Grid Size: {rows} rows × {cols} cols</p>\n125:             <p>Individual Plot: {plotLength.toFixed(2)} ft × {plotWidth.toFixed(2)} ft</p>\n126:           </div>\n127:         )}\n128: \n129:         {numPlots > 0 && (\n130:           <div \n131:             className=\"plot-preview\"\n132:             style={{\n133:               display: 'grid',\n134:               gridTemplateColumns: `repeat(${cols}, 40px)`,\n135:               gridTemplateRows: `repeat(${rows}, 40px)`,\n136:               gap: '4px',\n137:               marginTop: '16px'\n138:             }}\n139:           >\n140:             {Array.from({ length: numPlots }, (_, index) => (\n141:               <div\n142:                 key={index}\n143:                 style={{\n144:                   border: '1px solid #333',\n145:                   display: 'flex',\n146:                   alignItems: 'center',\n147:                   justifyContent: 'center',\n148:                   fontSize: '10px',\n149:                   backgroundColor: '#fff'\n150:                 }}\n151:               >\n152:                 {index + 1}\n153:               </div>\n154:             ))}\n155:           </div>\n156:         )}\n157: \n158:         <button type=\"submit\" className=\"submit-btn\">Create Project</button>\n159:       </form>\n160:     </div>\n161:   );\n162: };\n163: \n164: export default CreateProject;\n\n(End of file - total 164 lines)\n</content>",
