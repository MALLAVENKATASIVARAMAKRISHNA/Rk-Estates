          "tool": "write",
          "state": {
            "status": "completed",
            "input": {
              "content": "import React, { useState, useEffect } from 'react';\nimport { useRouter } from 'next/router';\n\nconst ManageProject = () => {\n  const router = useRouter();\n  const { id } = router.query;\n  const [project, setProject] = useState(null);\n  const [loading, setLoading] = useState(true);\n\n  useEffect(() => {\n    if (id) {\n      fetch(`/api/projects/${id}`)\n        .then(res => res.json())\n        .then(data => {\n          setProject(data);\n          setLoading(false);\n        })\n        .catch(err => {\n          console.error('Error:', err);\n          setLoading(false);\n        });\n    }\n  }, [id]);\n\n  if (loading) return <div>Loading...</div>;\n  if (!project) return <div>Project not found</div>;\n\n  return (\n    <div className=\"manage-project\">\n      <h1>{project.name}</h1>\n      <p>Location: {project.location}</p>\n      <div className=\"plots-grid\">\n        {project.plots && project.plots.map((plot) => (\n          <div key={plot.id} className=\"plot-card\">\n            <h3>Plot {plot.plotNumber}</h3>\n            <p>Status: {plot.status}</p>\n          </div>\n        ))}\n      </div>\n      <style jsx>{`\n        .manage-project {\n          padding: 20px;\n        }\n        .plots-grid {\n          display: grid;\n          grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\n          gap: 16px;\n          margin-top: 20px;\n        }\n        .plot-card {\n          border: 1px solid #ddd;\n          padding: 16px;\n          border-radius: 8px;\n        }\n      `}</style>\n    </div>\n  );\n};\n\nexport default ManageProject;\n",
              "filePath": "/home/tejasree/Rk-Estates/frontend/src/pages/admin/manage/[id].jsx"
